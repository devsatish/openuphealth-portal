{
  "name": "openuphealth-monorepo",
  "private": true,
  "packageManager": "pnpm@9.12.1",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile start",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter web prisma:generate",
    "db:migrate": "pnpm --filter web prisma:migrate",
    "db:seed": "pnpm --filter web db:seed"
  },
  "devDependencies": {
    "turbo": "^2.1.1",
    "typescript": "^5.6.2"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.12",
      "@types/react-dom": "^18.3.1"
    }
  }
}
