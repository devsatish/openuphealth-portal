{
  "extends": "../../packages/tsconfig/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@openup/types": [
        "../../packages/types/src"
      ],
      "@openup/validation": [
        "../../packages/validation/src"
      ],
      "@openup/domain": [
        "../../packages/domain/src"
      ],
      "@openup/ui": [
        "../../packages/ui/src"
      ],
      "@openup/config": [
        "../../packages/config/src"
      ],
      "@openup/api-client": [
        "../../packages/api-client/src"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "jsx": "preserve",
    "incremental": true,
    "isolatedModules": true,
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "typeRoots": ["./node_modules/@types", "./types"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
